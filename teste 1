local function teleportar(pos)

    local char = player.Character

    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(pos)
    end

end

-------------------------------------------------
-- PAINEL PRINCIPAL
-------------------------------------------------

local function abrirPainel()

    local frame = Instance.new("Frame", gui)
    frame.Size = UDim2.new(0,360,0,450)
    frame.Position = UDim2.new(0.1,0,0.2,0)
    frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
    frame.Active = true
    frame.Draggable = true

    RGBStroke(frame)

    local bg = Instance.new("ImageLabel", frame)
    bg.Size = UDim2.new(1,0,1,0)
    bg.BackgroundTransparency = 1
    bg.ImageTransparency = 0.4
    bg.Image = "rbxassetid://SEU_ID_DA_IMAGEM"

    local titulo = Instance.new("TextLabel", frame)
    titulo.Size = UDim2.new(1,0,0,40)
    titulo.Text = "Tropa Dos XYTEEY"
    titulo.Font = Enum.Font.GothamBlack
    titulo.TextScaled = true
    titulo.BackgroundColor3 = Color3.fromRGB(15,15,15)
    titulo.TextColor3 = Color3.new(1,1,1)

    local page1 = Instance.new("Frame", frame)
    page1.Size = UDim2.new(1,0,1,-60)
    page1.Position = UDim2.new(0,0,0,50)
    page1.BackgroundTransparency = 1

    local page2 = Instance.new("Frame", frame)
    page2.Size = page1.Size
    page2.Position = page1.Position
    page2.BackgroundTransparency = 1
    page2.Visible = false

    -------------------------------------------------
    -- TELEPORTS
    -------------------------------------------------

    local y = 0

    for _,dest in pairs(DESTINOS) do

        local btn = Instance.new("TextButton", page1)
        btn.Size = UDim2.new(0.8,0,0,30)
        btn.Position = UDim2.new(0.1,0,0,y)
        btn.Text = dest.nome

        btn.MouseButton1Click:Connect(function()
            teleportar(dest.pos)
        end)

        y = y + 35

    end

    -------------------------------------------------
    -- NAMELESS ADMIN
    -------------------------------------------------

    local adminButton = Instance.new("TextButton", page2)
    adminButton.Size = UDim2.new(0.8,0,0,40)
    adminButton.Position = UDim2.new(0.1,0,0.1,0)
    adminButton.Text = "Nameless Admin"
    adminButton.Font = Enum.Font.GothamBold

    adminButton.MouseButton1Click:Connect(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/ltseverydayyou/Nameless-Admin/main/Source.lua"))()
    end)

    -------------------------------------------------
    -- AIMBOT V1
    -------------------------------------------------

    local aimbot1 = Instance.new("TextButton", page2)
    aimbot1.Size = UDim2.new(0.8,0,0,40)
    aimbot1.Position = UDim2.new(0.1,0,0.3,0)
    aimbot1.Text = "Aimbot v1"
    aimbot1.Font = Enum.Font.GothamBold

    aimbot1.MouseButton1Click:Connect(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/Exunys/AirHub/main/AirHub.lua"))()
    end)

    -------------------------------------------------
    -- AIMBOT V2
    -------------------------------------------------

    local aimbot2 = Instance.new("TextButton", page2)
    aimbot2.Size = UDim2.new(0.8,0,0,40)
    aimbot2.Position = UDim2.new(0.1,0,0.5,0)
    aimbot2.Text = "Aimbot v2"
    aimbot2.Font = Enum.Font.GothamBold

    aimbot2.MouseButton1Click:Connect(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/ttwizz/Open-Aimbot/master/source.lua", true))()
    end)

    -------------------------------------------------
    -- BOTÃO MUDAR PAGINA
    -------------------------------------------------

    local mudar = Instance.new("TextButton", frame)
    mudar.Size = UDim2.new(0,40,0,40)
    mudar.Position = UDim2.new(1,-45,1,-45)
    mudar.Text = ">"

    local pagina = 1

    mudar.MouseButton1Click:Connect(function()

        if pagina == 1 then
            page1.Visible = false
            page2.Visible = true
            mudar.Text = "<"
            pagina = 2
        else
            page1.Visible = true
            page2.Visible = false
            mudar.Text = ">"
            pagina = 1
        end

    end)

    -------------------------------------------------
    -- TECLA K
    -------------------------------------------------

    UIS.InputBegan:Connect(function(input,gp)

        if gp then return end

        if input.KeyCode == ToggleKey then
            frame.Visible = not frame.Visible
        end

    end)

end

-------------------------------------------------
