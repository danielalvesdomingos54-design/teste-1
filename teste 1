-------------------------------------------------
-- RGB BORDA
-------------------------------------------------

local function RGBStroke(obj)

    local stroke = Instance.new("UIStroke", obj)
    stroke.Thickness = 3

    task.spawn(function()
        local h = 0
        while obj.Parent do
            h += 0.01
            stroke.Color = Color3.fromHSV(h,1,1)
            task.wait()
        end
    end)

end

